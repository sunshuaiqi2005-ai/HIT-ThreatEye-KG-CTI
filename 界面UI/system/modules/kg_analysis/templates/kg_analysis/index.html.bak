<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>知识图谱分析 - 威胁慧眼</title>
    <link href="https://cdn.bootcdn.net/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <script src="https://cdn.bootcdn.net/ajax/libs/vis-network/9.1.2/vis-network.min.js"></script>
    <style>
        #graph-container {
            width: 100%;
            height: 600px;
            border: 1px solid #ddd;
            background-color: #f8f9fa;
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="container mx-auto px-4 py-8">
        <!-- 标题 -->
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">知识图谱分析</h1>
            <button onclick="window.location.href='/'" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                返回主页
            </button>
        </div>

        <!-- 工具栏 -->
        <div class="bg-white p-4 rounded-lg shadow-md mb-6">
            <div class="flex space-x-4">
                <button onclick="loadGraph()" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">
                    加载图谱
                </button>
                <button onclick="analyzeGraph()" class="bg-purple-500 text-white px-4 py-2 rounded hover:bg-purple-600">
                    分析图谱
                </button>
            </div>
        </div>

        <!-- 图谱显示区域 -->
        <div class="bg-white p-4 rounded-lg shadow-md">
            <div id="graph-container"></div>
        </div>
    </div>

    <script>
        let network = null;

        // 初始化图谱
        function initGraph() {
            const container = document.getElementById('graph-container');
            const options = {
                nodes: {
                    shape: 'dot',
                    size: 16,
                    font: {
                        size: 12
                    }
                },
                edges: {
                    font: {
                        size: 12
                    },
                    arrows: {
                        to: { enabled: true, scaleFactor: 1 }
                    }
                },
                physics: {
                    stabilization: false,
                    barnesHut: {
                        gravitationalConstant: -80000,
                        springConstant: 0.001,
                        springLength: 200
                    }
                }
            };

            network = new vis.Network(container, { nodes: [], edges: [] }, options);
        }

        // 加载图谱数据
        async function loadGraph() {
            try {
                const response = await fetch('/kg_analysis/api/graph');
                const data = await response.json();
                
                const nodes = new vis.DataSet(data.nodes.map(node => ({
                    id: node.id,
                    label: node.label,
                    title: `类型: ${node.type}`,
                    color: getNodeColor(node.type)
                })));

                const edges = new vis.DataSet(data.edges.map(edge => ({
                    from: edge.source,
                    to: edge.target,
                    label: edge.label,
                    arrows: 'to'
                })));

                network.setData({ nodes, edges });
            } catch (error) {
                console.error('加载图谱失败:', error);
                alert('加载图谱失败，请重试');
            }
        }

        // 分析图谱
        async function analyzeGraph() {
            try {
                const response = await fetch('/kg_analysis/api/analyze', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        // 这里可以添加分析参数
                    })
                });
                const result = await response.json();
                alert(result.message);
            } catch (error) {
                console.error('分析失败:', error);
                alert('分析失败，请重试');
            }
        }

        // 根据节点类型设置颜色
        function getNodeColor(type) {
            const colors = {
                'ip': '#ff6b6b',
                'domain': '#4ecdc4',
                'malware': '#ffd93d',
                'group': '#95a5a6'
            };
            return colors[type] || '#95a5a6';
        }

        // 页面加载完成后初始化图谱
        document.addEventListener('DOMContentLoaded', initGraph);
    </script>
</body>
</html> 